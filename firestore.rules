rules_version = '2';
service cloud9.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitive Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Check if user is verified
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // --- Entity Specific Validators ---

    // 1. User Profile Validator
    function isValidUserProfile(data) {
      return data.keys().hasAll(['displayName', 'updatedAt']) 
        && data.keys().size() == 2
        && data.displayName is string 
        && data.displayName.size() > 0 
        && data.displayName.size() <= 128
        && data.updatedAt is timestamp;
    }

    // 2. Sovereign State Validator
    function isValidSovereignState(data) {
      return data.keys().hasAll(['userId', 'completedTasksCount', 'createdFormsCount', 'lastSyncedAt'])
        && data.keys().size() <= 5
        && data.userId == request.auth.uid
        && data.completedTasksCount is int
        && data.completedTasksCount >= 0
        && data.createdFormsCount is int
        && data.createdFormsCount >= 0
        && data.lastSyncedAt is timestamp;
    }

    // 3. Sovereign Mission Validator
    function isValidSovereignMission(data) {
      return data.keys().hasAll(['id', 'title', 'completed', 'source', 'createdAt'])
        && data.keys().size() <= 6
        && data.id is string
        && data.id.size() <= 128
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 200
        && data.completed is bool
        && data.source is string
        && (data.source == 'google_tasks' || data.source == 'sovereign_genie')
        && data.createdAt is timestamp;
    }

    // --- Collection Match Blocks ---

    // Matches /users/{userId} path
    match /users/{userId} {
      
      // Public Profile
      match /public/profile {
        allow read: if isSignedIn();
        allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
        allow update: if isOwner(userId) && isValidUserProfile(request.resource.data)
          && request.resource.data.displayName == resource.data.displayName; // displayName is immutable here for profile safety
      }

      // Private Sovereign State (PII Isolation and Strict Reads)
      match /private/sovereign_state {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSovereignState(request.resource.data);
        allow update: if isOwner(userId) && isValidSovereignState(request.resource.data);
      }

      // Sovereign Missions Sub-collection
      match /missions/{missionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(missionId) && isValidSovereignMission(request.resource.data);
        allow update: if isOwner(userId) && isValidId(missionId) && isValidSovereignMission(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(missionId);
      }
    }
  }
}
